{
    "Pablo: Static Website Template": {
        "prefix": "pablo-tpl-static",
        "body": [
            "name: \"${1:my-static-site}\"",
            "version: \"1.4.2\"",
            "",
            "profiles:",
            "  production:",
            "    type: static",
            "    output_dir:",
            "      dir: \"${2:dist}\"",
            "      include: [\"index.html\", \"assets/*\", \"*.css\", \"*.js\"]",
            "    environments:",
            "      web-server:",
            "        target_path: \"${3:/var/www/html}\"",
            "        strategy: overwrite",
            "        remote:",
            "          method: ssh",
            "          host: \"${4:server-ip-or-host}\"",
            "          credential: \"${5:ssh-cred-name}\""
        ],
        "description": "Ready-to-use template for Static Websites"
    },
    "Pablo: Node.js + PM2 Template": {
        "prefix": "pablo-tpl-node-pm2",
        "body": [
            "name: \"${1:node-api}\"",
            "version: \"1.4.2\"",
            "credentials:",
            "  ${2:ssh-key}:",
            "    type: ssh",
            "    key: \"~/.ssh/id_rsa\"",
            "",
            "profiles:",
            "  api-server:",
            "    type: binary",
            "    build:",
            "      command: \"npm install && npm run build\"",
            "    output_dir:",
            "      dir: \"dist\"",
            "    environments:",
            "      prod:",
            "        target_path: \"${3:/opt/app}\"",
            "        strategy: backup",
            "        remote:",
            "          method: ssh",
            "          host: \"${4:hostname}\"",
            "          credential: \"${2:ssh-key}\"",
            "        deploy:",
            "          service:",
            "            type: pm2",
            "            name: \"${1:node-api}\"",
            "            restart: true"
        ],
        "description": "Ready-to-use template for Node.js apps managed by PM2"
    },
    "Pablo: Go + Systemd Template": {
        "prefix": "pablo-tpl-go-systemd",
        "body": [
            "name: \"${1:go-service}\"",
            "version: \"1.4.2\"",
            "",
            "profiles:",
            "  backend:",
            "    type: binary",
            "    build:",
            "      command: \"go build -o ${1:go-service} main.go\"",
            "    output_dir:",
            "      dir: \".\"",
            "      include: [\"${1:go-service}\", \"config.yaml\"]",
            "    environments:",
            "      linux-server:",
            "        target_path: \"${2:/usr/local/bin}\"",
            "        strategy: backup",
            "        remote:",
            "          method: ssh",
            "          host: \"${3:server-host}\"",
            "          credential: \"${4:cred-name}\"",
            "        deploy:",
            "          service:",
            "            type: systemd",
            "            name: \"${1:go-service}\"",
            "            restart: true"
        ],
        "description": "Ready-to-use template for Go binary deployments with Systemd"
    },
    "Pablo: Docker Compose Template": {
        "prefix": "pablo-tpl-docker",
        "body": [
            "name: \"${1:docker-app}\"",
            "version: \"1.4.2\"",
            "",
            "profiles:",
            "  app-stack:",
            "    type: docker",
            "    git:",
            "      repo: \"${2:git@github.com:user/repo.git}\"",
            "      branch: \"main\"",
            "    environments:",
            "      swarm-cluster:",
            "        target_path: \"${3:/opt/docker-stack}\"",
            "        deploy:",
            "          docker:",
            "            compose_file: \"docker-compose.prod.yml\"",
            "            build: true",
            "            command: \"up -d\""
        ],
        "description": "Ready-to-use template for Docker Compose deployments"
    },
    "Pablo: Git-Sync Template": {
        "prefix": "pablo-tpl-gitsync",
        "body": [
            "name: \"${1:docs-sync}\"",
            "version: \"1.4.2\"",
            "",
            "profiles:",
            "  documentation:",
            "    type: git-sync",
            "    git:",
            "      repo: \"${2:url-to-repo}\"",
            "      branch: \"${3:main}\"",
            "    environments:",
            "      internal-server:",
            "        target_path: \"${4:/var/www/docs}\"",
            "        deploy:",
            "          remote: tar",
            "          strategy: overwrite"
        ],
        "description": "Ready-to-use template for Git repository synchronization"
    },
    "Pablo Config (Empty)": {
        "prefix": "pablo-config",
        "body": [
            "name: \"${1:project-name}\"",
            "version: \"1.4.2\"",
            "profiles:",
            "  ${2:profile-name}:",
            "    type: ${3|static,binary,docker,git-sync|}",
            "    environments:",
            "      ${4:env-name}:",
            "        target_path: \"${5:/path}\""
        ],
        "description": "Basic Pablo configuration skeleton"
    }
}